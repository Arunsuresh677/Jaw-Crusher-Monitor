# ═══════════════════════════════════════════════════════════════════
# Crusher Monitor — environment template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then edit .env with real credentials. .env is in .gitignore and
# must NEVER be committed.
# ═══════════════════════════════════════════════════════════════════

# ── Base directory (auto-detected if blank) ───────────────────────
# Defaults to the directory containing config.py.
# CRUSHER_BASE=/home/pi/kannan_backend

# ── RTSP camera (REQUIRED — credentials live here, not in source) ─
RTSP_URL=rtsp://admin:CHANGE_ME@192.168.0.124:1060/Streaming/Channels/101

# ── YOLO model file ───────────────────────────────────────────────
# MODEL_PATH=/home/pi/kannan_backend/weights/best.pt

# ── Output / log / static / DB paths (override if non-standard) ──
# OUTPUT_DIR=/home/pi/kannan_backend/output_frames
# LOG_DIR=/home/pi/kannan_backend/logs
# STATIC_DIR=/home/pi/kannan_backend/static
# DB_PATH=/home/pi/kannan_backend/crusher_data.db

# ── Server auth (REQUIRED — change AUTH_PASS for production) ─────
AUTH_USER=admin
AUTH_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD

# ═══════════════════════════════════════════════════════════════════
# VFD Modbus control
# ═══════════════════════════════════════════════════════════════════
# Set VFD_ENABLED=true once the RS-485 wiring is verified and the ABB
# drive parameters (58.01-58.06, 19.11, 28.11, 46.02) are set.
# Until then, keep VFD_ENABLED=false to run in monitor-only mode.
VFD_ENABLED=false

# Defaults below match ABB ACS580 with Embedded Fieldbus, ABB Drives
# Classic profile, motor nominal 50 Hz (par 46.02 = 50.00 Hz).
VFD_MODE=rtu
VFD_PORT=/dev/ttyUSB0
VFD_BAUDRATE=9600
VFD_PARITY=N
VFD_STOPBITS=1
VFD_BYTESIZE=8
VFD_SLAVE_ID=1
VFD_TIMEOUT=1.0
VFD_PROFILE=abb
VFD_INIT_SEQUENCE=true
VFD_MAX_HZ=50

# Register map — defaults for ABB ACS580
# (override these only for other brands; see config.py header)
# VFD_CMD_REGISTER=0x0000
# VFD_FREQ_REGISTER=0x0001
# VFD_SCALE=400
# VFD_CMD_RUN=0x047F
# VFD_CMD_STOP=0x047E

# ── Modbus TCP (only used when VFD_MODE=tcp) ─────────────────────
# VFD_TCP_HOST=192.168.0.200
# VFD_TCP_PORT=502
